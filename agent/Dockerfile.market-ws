# Market WS — caché multi-exchange + HTTP :8001 (mismo código que en host).
FROM python:3.12-slim-bookworm

WORKDIR /app

COPY agent/requirements-market-ws.txt /app/requirements-market-ws.txt
RUN pip install --no-cache-dir -r /app/requirements-market-ws.txt

COPY agent/ /app/

ENV PYTHONUNBUFFERED=1
EXPOSE 8001

HEALTHCHECK --interval=30s --timeout=8s --start-period=90s --retries=3 \
  CMD python -c "import urllib.request; urllib.request.urlopen('http://127.0.0.1:8001/health', timeout=5)"

CMD ["python", "market_ws_server.py"]
