# ─────────────────────────────────────────────────────────
# VERGE Agent — Environment Variables
# ─────────────────────────────────────────────────────────
# NOTE: Market DATA (prices, klines) does NOT require any keys.
#       These keys are only needed for actual order execution.
# ─────────────────────────────────────────────────────────

# Binance — Primary exchange (USDT-M Futures)
# Required for order execution on Binance.
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Bybit — Secondary exchange (USDT Perpetuals)
# Get at: https://www.bybit.com/app/user/api-management
BYBIT_API_KEY=
BYBIT_API_SECRET=

# OKX — Tertiary exchange (USDT Perpetuals)
# Get at: https://www.okx.com/account/my-api
OKX_API_KEY=
OKX_API_SECRET=
OKX_PASSPHRASE=

# Bitget — Quaternary exchange (USDT Futures)
# Get at: https://www.bitget.com/account/newapi
BITGET_API_KEY=
BITGET_API_SECRET=
BITGET_PASSPHRASE=

# ─────────────────────────────────────────────────────────
# ABP Backend
# ─────────────────────────────────────────────────────────
PYTHON_SERVICE_URL=http://localhost:8000
ABP_BACKEND_URL=https://localhost:44396
AGENT_USERNAME=agent@verge.internal
AGENT_PASSWORD=1q2w3E*

# ─────────────────────────────────────────────────────────
# Optional — Notifications
# ─────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─────────────────────────────────────────────────────────
# Optional — Sentiment Analysis
# ─────────────────────────────────────────────────────────
TWITTER_BEARER_TOKEN=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
